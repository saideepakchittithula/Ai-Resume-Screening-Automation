    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst output = {};\n\nlet count = 1;\n\nfor (const key in data) {\n  if (\n    key !== \"submittedAt\" &&\n    data[key] !== \"\" &&\n    data[key] !== null &&\n    data[key] !== undefined\n  ) {\n    output[`Question${count}`] = data[key];\n    count++;\n  }\n}\n\nif (data.submittedAt) {\n  output.submittedAt = data.submittedAt;\n}\n\nreturn [\n  {\n    json: output\n  }\n];"
      },
